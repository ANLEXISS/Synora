[Unit]
Description=Synora API
After=network.target synora-core.service synora-bus.service
Requires=synora-core.service synora-bus.service

[Service]
Type=simple

User=synora
Group=synora

ExecStart=/opt/synora/bin/synora-api

Restart=always
RestartSec=3

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
