# Synora Core / CGE Shadow physical-smoke profile.
# Copy this file to /etc/synora/synora-core.env during a future controlled
# installation. This repository example contains no secrets.

# Historical Shadow and its asynchronous durable workflow.
SYNORA_CGE_SHADOW_ENABLED=true
SYNORA_CGE_SHADOW_WORKFLOW_ENABLED=true
SYNORA_CGE_DATA_DIR=/var/lib/synora/cge
SYNORA_CGE_JOURNAL_PATH=/var/lib/synora/cge/journal.ndjson
SYNORA_CGE_INITIALIZE_IF_MISSING=true
SYNORA_CGE_JOURNAL_ID=physical-smoke-pass62

# The live Core read-only provider is wired automatically by synora-core.
SYNORA_CGE_SHADOW_CONTEXT_ENABLED=true
SYNORA_CGE_SHADOW_CONTEXT_TIMEZONE=UTC
SYNORA_CGE_SHADOW_CONTEXT_ALLOW_PARTIAL=true

# Keep all cognitive authority and optional learning paths disabled.
SYNORA_CGE_SHADOW_COGNITIVE_ENABLED=false
SYNORA_CGE_SHADOW_AUTO_EVIDENCE_ENABLED=false
SYNORA_CGE_SHADOW_ROUTINE_LEARNING_ENABLED=false
SYNORA_CGE_SHADOW_DEVIATION_ENABLED=false

# Durable calibration evidence. The ledger is bounded and fsync is explicit.
SYNORA_CGE_CALIBRATION_LEDGER_ENABLED=true
SYNORA_CGE_CALIBRATION_LEDGER_PATH=/var/lib/synora/cge/calibration-ledger.ndjson
SYNORA_CGE_CALIBRATION_LEDGER_FSYNC=true
SYNORA_CGE_CALIBRATION_LEDGER_MAX_BYTES=16777216
SYNORA_CGE_CALIBRATION_LEDGER_MAX_RECORDS=1000
SYNORA_CGE_CALIBRATION_LEDGER_REPAIR_TRAILING_RECORD=false

# Analytics are enabled but remain bounded and may report insufficient data
# during a short smoke. They never change decisions or policies.
SYNORA_CGE_CALIBRATION_ANALYTICS_ENABLED=true
SYNORA_CGE_CALIBRATION_ANALYTICS_MAX_WINDOWS=10

# Short qualification is opt-in for the future smoke procedure.
SYNORA_CGE_SHADOW_QUALIFICATION_ENABLED=false
SYNORA_CGE_FIELD_TRIAL_ENABLED=false
