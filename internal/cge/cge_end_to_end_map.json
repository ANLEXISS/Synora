{
  "schema_version": "cge-end-to-end-map-v1",
  "head": "dd3ae620cf8dc93a87dccce8af40e63e2c8d869",
  "entrypoints": [
    {
      "name": "core_bus_loop",
      "package": "cmd/synora-core",
      "file": "cmd/synora-core/main.go",
      "function": "coreApp.runBusLoop",
      "transport": "local Unix bus JSON lines",
      "input_type": "pkg/contract.Message",
      "output": "internal/ingest.Queue.Ingest or RPC queue"
    },
    {
      "name": "ingress_parser",
      "package": "internal/ingest",
      "file": "internal/ingest/ingest.go",
      "function": "Parser.Parse",
      "input_type": "pkg/contract.Message",
      "output_type": "pkg/contract.Event"
    }
  ],
  "stages": [
    {
      "order": 1,
      "name": "historical_ingress",
      "path": "bus -> runBusLoop -> Queue.Ingest -> Parser.Parse",
      "authority": "none",
      "mode": "historical"
    },
    {
      "order": 2,
      "name": "historical_decision",
      "path": "processEvent -> engine.Analyze/ObserveContext -> BuildResult",
      "output_type": "pkg/contract.Decision",
      "authority": "final historical decision",
      "mode": "historical"
    },
    {
      "order": 3,
      "name": "historical_state_and_consumers",
      "path": "stateapply.Apply -> StateStore -> automation -> action bus -> PublicSnapshot",
      "authority": "state publication and action request routing",
      "mode": "historical"
    },
    {
      "order": 4,
      "name": "shadow_cge_historical",
      "path": "deferred observeCGE -> ShadowEngine.Observe -> orchestration/journal",
      "authority": "diagnostic only",
      "mode": "shadow_historical"
    },
    {
      "order": 5,
      "name": "shadow_workflow",
      "path": "submitWorkflow -> TrySubmit -> bounded queue -> single worker",
      "authority": "none",
      "mode": "shadow_workflow_experimental"
    },
    {
      "order": 6,
      "name": "experimental_cognitive_layers",
      "path": "episodes -> situationfacts -> situationhypotheses -> evidencediscrimination -> advisoryrequests",
      "authority": "descriptive and consultative only",
      "mode": "shadow_workflow_experimental"
    },
    {
      "order": 7,
      "name": "optional_mapping_authorization",
      "path": "optional capabilitymapping -> optional authorizationboundary",
      "authority": "descriptive eligibility only; no grant or invocation",
      "mode": "shadow_workflow_experimental"
    },
    {
      "order": 8,
      "name": "durable_workflow",
      "path": "WorkflowMutation -> PlanTransaction -> WAL/fsync -> publish -> checkpoint/replay",
      "authority": "durability only",
      "mode": "shadow_workflow_experimental"
    }
  ],
  "decisions": [
    {
      "name": "historical_decision",
      "type": "pkg/contract.Decision",
      "constructed_by": "internal/engine/adapter.ToSynoraDecision and BuildResult",
      "orchestrated_by": "cmd/synora-core/coreApp.processEvent",
      "inputs": ["normalized event", "engine graph memory", "critical seeds", "danger context", "security profile", "state"],
      "consumers": ["stateapply.Apply", "automation.EvaluateRequests", "engine.decision publication", "PublicSnapshot"],
      "production_authority": true
    },
    {
      "name": "shadow_results",
      "type": "Shadow metrics, diagnostics and durable workflow assessments",
      "constructed_by": "internal/cge/shadow and internal/cge/shadowworkflow",
      "consumers": ["diagnostics", "qualification reporter", "workflow recovery"],
      "production_authority": false
    }
  ],
  "feature_flags": [
