# Inert reference only. Copy and adapt manually; no secret is included.
SYNORA_CGE_SHADOW_ENABLED=true
SYNORA_CGE_SHADOW_COGNITIVE_ENABLED=true
SYNORA_CGE_SHADOW_AUTO_EVIDENCE_ENABLED=false
SYNORA_CGE_SHADOW_CONTEXT_ENABLED=true
SYNORA_CGE_SHADOW_CONTEXT_TIMEZONE=Europe/Paris
SYNORA_CGE_SHADOW_CONTEXT_ALLOW_PARTIAL=true
SYNORA_CGE_SHADOW_ROUTINE_LEARNING_ENABLED=true
SYNORA_CGE_SHADOW_ROUTINE_TEMPORAL_BUCKET_MINUTES=15
SYNORA_CGE_SHADOW_ROUTINE_ALLOW_PARTIAL=true
SYNORA_CGE_SHADOW_ROUTINE_MAX_TRANSITION_GAP=15m
SYNORA_CGE_SHADOW_ROUTINE_REQUIRE_SAME_TOPOLOGY_REVISION=true
SYNORA_CGE_SHADOW_DEVIATION_ENABLED=true
SYNORA_CGE_SHADOW_DEVIATION_RECENT_LIMIT=256
SYNORA_CGE_SHADOW_DEVIATION_MAX_ASSESSMENTS_PER_OBSERVATION=2
SYNORA_CGE_FIELD_TRIAL_ENABLED=true
SYNORA_CGE_FIELD_TRIAL_ROOT=/var/lib/synora/cge-field-trials
SYNORA_CGE_FIELD_TRIAL_SEGMENT_MAX_BYTES=16777216
SYNORA_CGE_FIELD_TRIAL_RETENTION_DAYS=45
SYNORA_CGE_FIELD_TRIAL_MAX_TOTAL_BYTES=536870912
SYNORA_CGE_FIELD_TRIAL_SYNC_EACH_EVENT=false
SYNORA_CGE_FIELD_TRIAL_INCLUDE_CONTEXT=true
SYNORA_CGE_FIELD_TRIAL_INCLUDE_LATENCIES=true

# Required operator-provided values; never commit a key.
SYNORA_CGE_FIELD_TRIAL_SESSION_ID=
SYNORA_CGE_FIELD_TRIAL_KEY_FILE=
SYNORA_CGE_FIELD_TRIAL_TOPOLOGY_FILE=
